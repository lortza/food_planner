<% content_for(:title, 'Save a Pending Recipe') %>

<p><%= link_to MaterialIcon.new(icon: :arrow_left).render + 'Recipes', recipes_path %></p>

<h1>Save a Pending Recipe</h1>

<div data-controller="loading-spinner">
  <div data-loading-spinner-target="loading" class="hidden">
    <%= render partial: "shared/recipe_parsing_loading_state" %>
  </div>

  <%= form_with(model: current_user.tags.new, url: tags_path, html: { id: "tag-creation" }) do %>
  <% end %>

  <div data-loading-spinner-target="form">
    <%= form_with model: @recipe, url: pending_recipes_path, method: :post, data: { action: "submit->loading-spinner#show" } do |form| %>
    <%= render 'shared/errors', object: @recipe %>
    <%= form.hidden_field :status %>

    <div class="field mb-3">
      <%= form.label "Source URL*" %>
      <%= form.text_field :source_url, autofocus: true, class: 'form-control' %>
    </div>

    <div class="field mb-3">
      <%= form.label "Title" %>
      <%= form.text_field :title, class: 'form-control' %>
    </div>

    <div class="field mb-3">
      <%= label_tag :body, "Body" %>
      <p class="form-text text-muted">If you have the recipe instructions in a text format, you can paste them here. The system will attempt to extract the relevant information from the text.</p>
      <%= text_area_tag :body, nil,{class: 'form-control'} %>
    </div>

    <div class="mb-3">
      <%= form.label :image_url %>
      <%= form.text_field :image_url, class: 'form-control' %>
    </div>

    <div class="field mb-3">
      <%= form.label :notes %>
      <%= form.text_area :notes, class: 'form-control' %>
    </div>

    <%= render partial: "recipes/tags_fields", locals: {form: form, tag_form_id: "tag-creation"} %>

    <%= form.submit class: button_classes('primary mt-3') %>
    <% end %>
  </div>
</div>
