<% content_for(:title, @shopping_list.name) %>

<p><%= link_to MaterialIcon.new(icon: :arrow_left).render + 'Shopping Lists', shopping_lists_path %></p>

<%= tag.div(data: { controller: "toggle-visibility" }) do %>
  <header class="d-flex justify-content-between align-items-center">
    <h1><%= @shopping_list.name %></h1>
    <div class='d-flex align-items-center'>
      <%= link_to MaterialIcon.new(icon: :calendar_meal, size: :xxlarge, title: 'Toggle current meal plan').render, '#', class: "me-2", data: {action: "toggle-visibility#toggle"} if upcoming_meal_plan %>
      <%= link_to MaterialIcon.new(icon: :truck, size: :xxlarge, title: 'Schedule an upcoming delivery').render, new_shopping_list_scheduled_delivery_path(@shopping_list), class: "me-2" %>
      <%= link_to MaterialIcon.new(icon: :sync, size: :xxlarge).render, @shopping_list %>
    </div>
  </header>

  <%= tag.article(id: dom_id(@shopping_list, :item_search_form)) do %>
    <%= form_with(url: search_shopping_list_path(@shopping_list), method: :get, id: 'search-form',
                  data: { controller: "search", turbo_frame: dom_id(@shopping_list, :search_results) }) do %>
      <div class="col-xs-12">
        <%= text_field_tag :search, nil,
            placeholder: 'Find or Add an item...',
            class: 'form-control form-control-sm',
            autocomplete: 'off',
            data: { search_target: "input", action: "input->search#submit" } %>
      </div>
    <% end %>
    <%= turbo_frame_tag dom_id(@shopping_list, :search_results), target: "_top" %>
  <% end %>

  <% if upcoming_meal_plan %>
    <%= tag.div(data: {"toggle-visibility-target": "content"}, class: "hidden") do %>
      Recipes for <%= upcoming_meal_plan.prepared_on %>:
      <ul>
        <% upcoming_meal_plan.recipes.each do |recipe| %>
          <li><%= link_to recipe.title, recipe_path(recipe) %></li>
        <% end %>
      </ul>
    <% end %>
  <% end %>
<% end %>

<%= render 'scheduled_deliveries/scheduled_deliveries', shopping_list: @shopping_list %>
<%= render partial: 'shopping_list_items/active_items', locals: { shopping_list: @shopping_list } %>

<h4 class='aisle'>Crossed Off</h4>
<section id='js-inactive-items' class='inactive-items'>
  <% @shopping_list.shopping_list_items.includes(:list).inactive.by_recently_edited.limit(30).each do |item| %>
    <%= render partial: '/shopping_list_items/item', locals: { item: item, destination_path: activate_shopping_list_item_path(item) } %>
  <% end %>
</section>
