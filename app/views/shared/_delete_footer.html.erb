<details>
  <summary class='mt-4 border-top border-secondary'><h5 class="inline-block pt-3">Danger Zone</h5></summary>
  <footer>
    <p>Deleting this <%= object.class.name %> cannot be undone.
      <%= link_to "Click to delete #{object.class.name.downcase}", delete_path, data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this #{object.class.name.downcase}? This action cannot be undone." }, class: "text-danger" %>.
    </p>
  </footer>
</details>
